[
	{
		"context": "Workspace && !Terminal && !CommandPalette",
		"bindings": {
			"alt-h": "workspace::ActivatePaneLeft",
			"alt-l": "workspace::ActivatePaneRight",
			"alt-k": "workspace::ActivatePaneUp",
			"alt-j": "workspace::ActivatePaneDown",

			"cmd-t": "workspace::NewCenterTerminal",

			// bujo tasks
			"cmd-g n": ["task::Spawn", { "task_name": "Bujo current" }],
			"cmd-g s": ["task::Spawn", { "task_name": "Bujo search" }],
			"cmd-g f": ["task::Spawn", { "task_name": "Bujo next" }],
			"cmd-g F": ["task::Spawn", { "task_name": "Bujo forward" }],
			"cmd-g b": ["task::Spawn", { "task_name": "Bujo previous" }],
			"cmd-g B": ["task::Spawn", { "task_name": "Bujo backward" }],
			"cmd-g S": ["task::Spawn", { "task_name": "Bujo sync" }],
		},
	},
]

#!/usr/bin/env bash

# TODO: this depends on vcpkg, which is later in the install process on a fresh mac (alphabetically)

set -e

bujo_root="${HOME}/git/timhugh/bujo"
if [ ! -d "$bujo_root" ]; then
    mkdir -p ~/git/timhugh
    git clone https://github.com/timhugh/bujo.git ~/git/timhugh/bujo
fi


if ! command -v bujo &> /dev/null; then
    cd "${bujo_root}"
    make
    sudo make install
fi
